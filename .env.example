# ===== Sak Sales — Environment Variables =====
# คัดลอกไฟล์นี้เป็น .env.local สำหรับรันในเครื่อง
# และตั้งค่าเดียวกันใน Vercel → Project → Settings → Environment Variables

# --- บัญชีแอดมิน (ใช้ล็อกอินหน้า /admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=เปลี่ยนรหัสนี้ให้ปลอดภัย

# --- คีย์เซ็นเซสชัน (สุ่มข้อความยาว ๆ มาวาง) ---
SESSION_SECRET=ใส่ข้อความสุ่มยาวอย่างน้อย32ตัวอักษร

# --- ไอดีไลน์ที่แสดงปุ่มให้ลูกค้า (ขึ้นต้น @ ถ้าเป็น LINE Official) ---
NEXT_PUBLIC_LINE_ID=@saksales

# --- Vercel Blob (เก็บไฟล์ PDF) ---
# ค่านี้ Vercel จะใส่ให้อัตโนมัติเมื่อสร้าง Blob Store แล้วเชื่อมกับโปรเจค
# ถ้าจะรันในเครื่อง ให้ก็อปจาก Vercel → Storage → Blob → .env
BLOB_READ_WRITE_TOKEN=
